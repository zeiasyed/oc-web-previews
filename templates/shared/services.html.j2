<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Services | {{ business.name }}</title>
  <meta name="description" content="{{ tagline }}">
  <link rel="stylesheet" href="styles.css">
</head>
<body>
{% include '_preview_bar.html.j2' %}
  <header class="site-header">
    <div class="container header-inner">
      <div class="logo">{{ business.name }}</div>
      <nav>
        <a href="index.html">Home</a>
        <a href="services.html" class="active">Services</a>
        <a href="about.html">About</a>
        {% if is_trade %}<a href="blog.html">Tips &amp; Guides</a>{% endif %}
        <a href="contact.html" class="btn btn-small">Contact</a>
      </nav>
    </div>
  </header>

  <main>
    <section class="page-hero{% if is_trade %} page-hero-image{% endif %}"{% if is_trade %} style="background-image: linear-gradient(rgba(15,23,42,0.72), rgba(15,23,42,0.72)), url('{{ hero_image }}');"{% endif %}>
      <div class="container">
        <p class="eyebrow{% if is_trade %} eyebrow-light{% endif %}">{{ industry_label }}</p>
        <h1>Our Services</h1>
        <p class="lead">{{ tagline }}</p>
      </div>
    </section>

    <section class="section">
      <div class="container">
        {% if is_trade %}
        <div class="service-grid service-grid-page">
          {% for service in services %}
          <article class="service-tile service-tile-large">
            {% if service.image_secondary %}
            <div class="service-tile-images-duo service-tile-images-duo-large">
              <img src="{{ service.image }}" alt="{{ service.title }} fixture" class="service-tile-image">
              <img src="{{ service.image_secondary }}" alt="{{ service.title }} pipes" class="service-tile-image">
            </div>
            {% elif service.image %}
            <img src="{{ service.image }}" alt="{{ service.title }}" class="service-tile-image">
            {% endif %}
            <div class="service-tile-body">
              <h2>{{ service.title }}</h2>
              <p>{{ service.description }}</p>
              <p class="muted">Available throughout {{ business.city }} and surrounding areas.</p>
            </div>
          </article>
          {% endfor %}
        </div>
        {% else %}
        <div class="service-cards">
          {% for service in services %}
          <article class="service-card">
            <h2>{{ service.title if service.title is defined else service }}</h2>
            <p>Professional {{ industry_label|lower }} for homes and businesses across {{ business.city }}.</p>
          </article>
          {% endfor %}
        </div>
        {% endif %}
      </div>
    </section>

    {% if is_trade %}
    <section class="cta-banner">
      <div class="container cta-inner">
        <div>
          <h2>{{ cta_headline }}</h2>
          <p>{{ cta_text }}</p>
        </div>
        <div class="cta-actions">
          <a href="contact.html" class="btn btn-light">Request an Estimate</a>
        </div>
      </div>
    </section>
    {% endif %}
  </main>

{% include '_footer.html.j2' %}
</body>
</html>
