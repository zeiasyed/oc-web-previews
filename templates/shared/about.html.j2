<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>About | {{ business.name }}</title>
  <link rel="stylesheet" href="styles.css">
</head>
<body>
{% include '_preview_bar.html.j2' %}
  <header class="site-header">
    <div class="container header-inner">
      <div class="logo">{{ business.name }}</div>
      <nav>
        <a href="index.html">Home</a>
        <a href="services.html">Services</a>
        <a href="about.html" class="active">About</a>
        {% if is_trade %}<a href="blog.html">Tips &amp; Guides</a>{% endif %}
        <a href="contact.html" class="btn btn-small">Contact</a>
      </nav>
    </div>
  </header>

  <main>
    <section class="page-hero">
      <div class="container">
        <p class="eyebrow-dark">{{ industry_label }}</p>
        <h1>About {{ business.name }}</h1>
      </div>
    </section>

    <section class="section">
      <div class="container split">
        <div>
          <p class="lead">{{ about_text }}</p>
          <p>We proudly serve {{ business.city }} and surrounding cities. Whether you need help today or want a trusted partner for the long run, we're here to deliver dependable service.</p>
          {% if trust_badges %}
          <ul class="trust-badges trust-badges-inline">
            {% for badge in trust_badges %}
            <li>{{ badge }}</li>
            {% endfor %}
          </ul>
          {% endif %}
        </div>
        <div class="card">
          <img src="{{ section_image }}" alt="About {{ business.name }}" class="card-image">
        </div>
      </div>
    </section>

    <section class="section section-muted">
      <div class="container">
        <h2>Our commitment to you</h2>
        <div class="features">
          {% for feature in features %}
          <article>
            <h3>{{ feature.title }}</h3>
            <p>{{ feature.description }}</p>
          </article>
          {% endfor %}
        </div>
      </div>
    </section>
  </main>

{% include '_footer.html.j2' %}
</body>
</html>
